# ═══ PRODUCTION-DISCIPLINE §1 (env split) ════════════════════════════
# .env.local must ONLY ever hold the DEV Supabase project's URLs/keys.
# Prod secrets live exclusively in GitHub Actions secrets + `wrangler secret` —
# never on a laptop. No prod dumps locally (donor/volunteer PII).
# ═════════════════════════════════════════════════════════════════════

# ── Database (Supabase) ───────────────────────────────────────────────
# App connection — Supabase pooler, port 6543, transaction mode (prepare:false in code)
DATABASE_URL=postgres://postgres.PROJECTREF:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres
# Migrations only — direct connection, port 5432 (drizzle-kit)
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres

# ── Clerk (auth) ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Supabase Storage (Phase 2)
SUPABASE_URL=https://PROJECTREF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_from_supabase_dashboard
SUPABASE_STORAGE_BUCKET=pickups

# ── Supabase — browser client for Live Tracking (Phase 3) ─────────────
# PUBLIC by design: the anon key grants nothing on its own — RLS + a valid
# Clerk-issued token gate every read. Same project URL as SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECTREF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ── Inngest — async job orchestration (Phase 4) ───────────────────────
# Keys from the Inngest dashboard; already in .env.local. Also set as Cloudflare secrets.
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=signkey-your-inngest-signing-key

# ── Resend — transactional email over REST/fetch (Phase 4) ────────────
# From onboarding@resend.dev until a domain is verified (deferred); sandbox delivers
# only to the account owner's address.
RESEND_API_KEY=re_your_resend_key

# ── Web Push VAPID keypair (Phase 4) ──────────────────────────────────
# Generate once: npx web-push generate-vapid-keys (local Node, gen only).
# The PUBLIC key is also exposed to the browser as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:rajyashfoundation@rajyashgroup.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ── Payments / Razorpay donation scaffold (Phase 5, PAY-01..04) ───────
# DARK BY DEFAULT. Leave PAYMENTS_ENABLED and NEXT_PUBLIC_PAYMENTS_ENABLED UNSET to
# keep the entire donation surface inert (no /donate page, no order action, webhook
# 404s). The credentials below are OPTIONAL and only read once the flag is on — the
# app boots fine with them unset. To go live: clear Razorpay NGO KYC, paste live keys,
# register the webhook URL in the Razorpay dashboard, apply the migration, then set the
# two flags to 1. Explicit-truthy parse: ONLY "1" or "true" enables; unset / "false" /
# "0" / "" all keep it OFF (so setting =false to be explicit is safe).
# PAYMENTS_ENABLED=1
# NEXT_PUBLIC_PAYMENTS_ENABLED=1
# RAZORPAY_KEY_ID=rzp_live_or_test_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=the_secret_you_set_when_registering_the_webhook
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_or_test_key_id

# ── Cloudflare Turnstile — abuse gate on the (unauthenticated) donate flow (MED-1) ────
# OPTIONAL. When unset, the donate widget isn't rendered and the server verification
# skips — donations work as before. Set BOTH to arm the bot-check before live payments.
# Create at Cloudflare dashboard → Turnstile → Add site (site key is public, secret is
# server-only → set as a Worker secret, never in the client bundle).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_your_site_key
# TURNSTILE_SECRET_KEY=0x4AAAAAAA_your_secret_key
